{
  "name": "fm26-kit-creator",
  "version": "1.0.0",
  "description": "Desktop application for creating Football Manager 2026 kits",
  "homepage": "https://github.com/tonym6350-star/fm26-kit-creator",
  "author": "tonym6350-star",
  "license": "MIT",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "wait-on http://localhost:3000 && concurrently \"cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "start": "concurrently npm:react-start npm:electron-start",
    "build": "npm run react-build && electron-builder",
    "build-publish": "npm run react-build && electron-builder -p always",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "build": {
    "appId": "com.fm26.kit",
    "productName": "FM26 Kit Creator",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "certificateFile": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FM26 Kit Creator"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-updater": "^6.1.0",
    "fabric": "^5.3.0",
    "zustand": "^4.4.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "electron-is-dev": "^2.0.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.0",
    "cross-env": "^7.0.0"
  }
}